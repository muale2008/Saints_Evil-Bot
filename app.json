{
  "name": "Saints_Evil-Bot",
  "description": "WhatsApp automation bot",
  "keywords": [
    "whatsapp-bot",
    "automation",
    "baileys"
  ],
  "repository": "https://github.com/muale2008/Saints_Evil-Bot",
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Put your session id",
      "required": true,
      "value": ""
    },
    "MONGO_URL": {
      "description": "MongoDB database URL",
      "required": false,
      "value": "mongodb+srv://Saints_Evil-Bot:muale2008@cluster0.umi5clq.mongodb.net/saintsbot"
    },
    "MYSQL_URL": {
      "description": "MySQL database URL",
      "required": false,
      "value": ""
    },
    "POSTGRES_URL": {
      "description": "Postgres database URL",
      "required": false,
      "value": ""
    },
    "PREFIXES": {
      "description": "One or more prefixes separated by comma",
      "required": false,
      "value": ".,!,/"
    },
    "PACKNAME": {
      "description": "Your sticker pack name",
      "required": false,
      "value": "Saints_Evil-Bot"
    },
    "BOT_NAME": {
      "description": "Your bot name",
      "required": false,
      "value": "SAINTS-EVIL-BOT"
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number",
      "required": false,
      "value": "233206777968"
    },
    "COMMAND_MODE": {
      "description": "Bot mode",
      "required": false,
      "value": "service"
    },
    "BOT_OWNER": {
      "description": "Owner name",
      "required": false,
      "value": "Saint"
    },
    "TIMEZONE": {
      "description": "Your time zone",
      "required": false,
      "value": "Africa/Accra"
    },
    "REMOVEBG_KEY": {
      "description": "Remove background API key",
      "required": false,
      "value": "YV8mSvfiB2whNrYcZtDTxM3H"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}